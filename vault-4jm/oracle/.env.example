# Auditor server env — copy to oracle/.env and fill in

# Private key for the wallet that signs NAV updates.
# After deploy: call oracle.addAuditor(<this wallet address>)
AUDITOR_PRIVATE_KEY=0x...

# Deployed FundVault address (bound inside the EIP-712 struct)
VAULT_ADDRESS=0x...

# Deployed NAVOracle address (used as EIP-712 domain verifyingContract)
ORACLE_ADDRESS=0x...

# Simple secret for POST /nav — manager uses this to push new NAV values
MANAGER_SECRET=change-me

# Base Sepolia = 84532 | Base mainnet = 8453
CHAIN_ID=84532

# RPC endpoint — required for sign-nav.js --submit and for nonce auto-fetch
RPC_URL=https://sepolia.base.org

PORT=3001
