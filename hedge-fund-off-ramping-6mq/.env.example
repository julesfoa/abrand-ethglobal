# ── Auditor signing key ──────────────────────────────────────────────────────
# The private key whose address is registered as an auditor in NAVOracle.sol.
# In production: HSM or KMS-managed key, NOT an EOA.
AUDITOR_PRIVATE_KEY=0x...

# ── Chain: Arc testnet ────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.arcprotocol.xyz
ARC_VAULT_ADDRESS=0x...
ARC_ORACLE_ADDRESS=0x...
ARC_MOCK_ROUTER_ADDRESS=0x...

# ── Chain: Base Sepolia ───────────────────────────────────────────────────────
# On Base Sepolia, Chainlink Automation triggers the fetch cycle automatically.
# The keeper only needs to keep the nav-attestation API up to date.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_VAULT_ADDRESS=0x...
BASE_ORACLE_ADDRESS=0x...

# ── Exchange: Coinbase Prime ──────────────────────────────────────────────────
# Sub-account whose equity is used as the NAV source.
# Permissions required: read portfolio balance (read-only key is sufficient).
COINBASE_PRIME_API_KEY=
COINBASE_PRIME_API_SECRET=
COINBASE_PRIME_PASSPHRASE=
COINBASE_PRIME_PORTFOLIO_ID=

# ── Exchange: Binance (alternative) ──────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SUBACCOUNT_EMAIL=

# ── NAV source override ───────────────────────────────────────────────────────
# Force a specific NAV (1e6 = $1.00). Overrides exchange fetch. Demo/testing only.
# DEMO_NAV_OVERRIDE=1050000

# ── Keeper config ─────────────────────────────────────────────────────────────
# How often to push NAV updates (ms). Must be < maxNavStaleness in FundVault.
KEEPER_INTERVAL_MS=600000   # 10 minutes
